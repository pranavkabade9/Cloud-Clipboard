{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and usage metadata",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "storageUsed": { "type": "number", "description": "Bytes used" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "storageUsed"]
    },
    "ClipboardItem": {
      "title": "Clipboard Item",
      "description": "A saved clipboard entry",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "image"] },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "size": { "type": "number", "description": "Size in bytes" },
        "labelId": { "type": "string" },
        "pinned": { "type": "boolean" },
        "archived": { "type": "boolean" },
        "deleted": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "createdAt"]
    },
    "Label": {
      "title": "Label",
      "description": "Custom label for organizing items",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User account info"
    },
    "/clipboardItems/{itemId}": {
      "schema": "ClipboardItem",
      "description": "All clipboard items"
    },
    "/labels/{labelId}": {
      "schema": "Label",
      "description": "User defined labels"
    }
  }
}
